$var wire 1 * rx_timeout $end
$var wire 1 + sys_clk $end
$var wire 1 , sys_rst $end
$var wire 1 - usb_clk $end
$var wire 1 . usb_rst $end
$enddefinitions $end
$dumpvars
$end
