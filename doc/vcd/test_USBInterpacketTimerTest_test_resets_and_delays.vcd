$scope module USBInterpacketTimer $end
$var wire 2 ! usbinterpackettimer0 $end
$var wire 1 " usbinterpackettimer1 $end
$var wire 1 # usbinterpackettimer2 $end
$var wire 1 $ usbinterpackettimer3 $end
$var wire 10 % usbinterpackettimer_counter $end
$var wire 1 & usbinterpackettimer4 $end
$var wire 1 ' start $end
$var wire 1 ( tx_allowed $end
$var wire 1 ) tx_timeout $end
$var wire 1 * rx_timeout $end
$var wire 1 + sys_clk $end
$var wire 1 , sys_rst $end
$var wire 1 - usb_clk $end
$var wire 1 . usb_rst $end
$enddefinitions $end
$timescale 17ns $end
$dumpvars
$end
